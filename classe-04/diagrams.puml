@startuml
title E-Commerce System Overview

actor Customer
actor Admin
actor PaymentGateway as PG
actor ShippingService as SS
actor InventorySystem as IS

rectangle "Web Storefront" {
  component "Product Catalog" as Catalog
  component "Shopping Cart" as Cart
  component "Order Processing" as OrderProc
  component "User Account" as Account
}

rectangle "Back Office" {
  component "Inventory Service" as Inventory
  component "Payment Service" as Payment
  component "Shipping Service" as Shipping
  component "Analytics / Reporting" as Analytics
}

Customer --> Catalog : browse/search products
Customer --> Cart : add/remove items
Customer --> Account : login/register
Customer --> OrderProc : place order

Account --> OrderProc : manage profile / order history
OrderProc --> Payment : initiate payment
Payment --> PG : process payment
OrderProc --> Inventory : reserve stock
OrderProc --> Shipping : request shipment
Shipping --> SS : ship order
Inventory --> IS : update stock

Admin --> Inventory : manage inventory
Admin --> Catalog : manage products
Admin --> Analytics : view sales

Cart --> Catalog : get product details
OrderProc --> Cart : validate order
Payment --> OrderProc : payment status
Shipping --> OrderProc : shipment status

@enduml
